# Copy this file to .env and fill in your values
MYSQL_HOST=35.234.220.201
MYSQL_PORT=3306
MYSQL_DB=bcd_questionnaire
MYSQL_USER=tanuh-bcd-portal@bcd-prototypes.iam.gserviceaccount.com
MYSQL_PASSWORD=
MYSQL_DRIVER=pymysql
MYSQL_QUERY=charset=utf8mb4

# Cloud SQL Connector (handles SSL + IAM token generation automatically)
CLOUD_SQL_CONNECTION_NAME=bcd-prototypes:asia-south1:tanuh-bcd-questionnaire-dev
USE_CLOUD_SQL_CONNECTOR=true

# GCP
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json

# SSL certs not needed when using Cloud SQL Connector
MYSQL_SSL_CA=
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=

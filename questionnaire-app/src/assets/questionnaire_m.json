{
  "sections": [
    {
      "title": "Section 1: General Information",
      "questions": [
        {
          "id": "q1_age",
          "text": "1. What is your current age?",
          "type": "number",
          "placeholder": "e.g., 35"
        },
        {
          "id": "q2_height_weight",
          "text": "2. What is your height and weight?",
          "type": "inline-inputs",
          "inputs": [
            {
              "id": "q2_height_cm",
              "placeholder": "Height (cm)",
              "type": "number"
            },
            {
              "id": "q2_weight_kg",
              "placeholder": "Weight (kg)",
              "type": "number"
            }
          ]
        },
        {
          "id": "q3_state",
          "text": "3. Which state or union territory best represents the place where you have lived for a significant part of your life?",
          "type": "select",
          "options": [
            "Select your state/UT",
            "Andhra Pradesh",
            "Arunachal Pradesh",
            "Assam",
            "Bihar",
            "Chhattisgarh",
            "Goa",
            "Gujarat",
            "Haryana",
            "Himachal Pradesh",
            "Jharkhand",
            "Karnataka",
            "Kerala",
            "Madhya Pradesh",
            "Maharashtra",
            "Manipur",
            "Meghalaya",
            "Mizoram",
            "Nagaland",
            "Odisha",
            "Punjab",
            "Rajasthan",
            "Sikkim",
            "Tamil Nadu",
            "Telangana",
            "Tripura",
            "Uttar Pradesh",
            "Uttarakhand",
            "West Bengal",
            "Andaman and Nicobar Islands",
            "Chandigarh",
            "Dadra and Nagar Haveli and Daman and Diu",
            "Delhi",
            "Jammu and Kashmir",
            "Ladakh",
            "Lakshadweep",
            "Puducherry"
          ]
        },
        {
          "id": "q4_income",
          "text": "4. Please indicate your family's approximate annual household income range?",
          "type": "radio",
          "options": [
            "Less than \u20b92,00,000 per annum",
            "Between \u20b92,00,000 and \u20b95,00,000 per annum",
            "Between \u20b95,00,000 and \u20b910,00,000 per annum",
            "Greater than \u20b910,00,000 per annum"
          ]
        },
        {
          "id": "q5_education",
          "text": "5. What is your highest educational qualification?",
          "type": "radio",
          "options": [
            "No formal education",
            "<10 years of Schooling",
            "Intermediate Education",
            "Graduation & Above"
          ]
        },
        {
          "id": "q6_diabetes",
          "text": "6. Have you been diagnosed with diabetes?",
          "type": "radio",
          "options": [
            "Yes",
            "No",
            "I don't know"
          ]
        },
        {
          "id": "q7_hypertension",
          "text": "7. Have you been diagnosed with high blood pressure (hypertension)?",
          "type": "radio",
          "options": [
            "Yes",
            "No",
            "I don't know"
          ]
        },
        {
          "id": "q8_menstrual_period",
          "text": "8. Have you had a menstrual period?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q8a_first_period_age",
              "text": "8a. What was your age when you had your first menstrual period?",
              "type": "number",
              "placeholder": "Please enter a number - years"
            },
            {
              "id": "q8b_menopausal_status",
              "text": "8b. Which of these best describes your menopausal status?",
              "type": "radio",
              "options": [
                "Premenopausal (still having periods) - regular cycles",
                "Premenopausal (still having periods) - irregular cycles",
                "Perimenopausal (periods are irregular or have stopped for less than 12 months)",
                "Postmenopausal (periods have stopped for 12 consecutive months or more)"
              ]
            }
          ]
        },
        {
          "id": "q9_marital_status",
          "text": "9. What is your Marital Status?",
          "type": "radio",
          "options": [
            "Married",
            "Never Married"
          ]
        },
        {
          "id": "q10_given_birth",
          "text": "10. Have you given birth to one or more children?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q10a_children_number",
              "text": "10a. Number of children:",
              "type": "number",
              "placeholder": "Please enter a number"
            },
            {
              "id": "q10b_age_at_births",
              "text": "10b. Your age at every child birth (Please enter comma-separated ages)",
              "type": "text",
              "placeholder": "e.g., 25,28"
            },
            {
              "id": "q10c_breastfeeding_duration",
              "text": "10c. Total Duration of breast feeding (Please enter a number - years and months)",
              "type": "text",
              "placeholder": "e.g., 2 years 6 months"
            }
          ]
        },
        {
          "id": "q11_tobacco",
          "text": "11. Have you smoked cigarettes, bidis, or used any other form of tobacco?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ]
        },
        {
          "id": "q12_alcohol",
          "text": "12. Do you consume alcohol?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ]
        },
        {
          "id": "q13_relatives_cancer",
          "text": "13. Have any relatives been diagnosed with any type of cancer?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q13a_relation",
              "text": "13a. Please enter the relation with relative",
              "type": "text",
              "placeholder": "e.g., Mother, Sister, Uncle"
            },
            {
              "id": "q13b_diagnosis_age",
              "text": "13b. Please enter the age of diagnosis",
              "type": "number",
              "placeholder": "e.g., 45"
            },
            {
              "id": "q13c_cancer_types",
              "text": "13c. Please specify which types of cancer",
              "type": "checkbox-plus-text",
              "options": [
                "Breast cancer",
                "Ovarian cancer",
                "Colon, rectal, or pancreatic cancer",
                "Uterine cancer",
                "Prostate cancer"
              ],
              "otherOptionId": "q13c_other_cancer_specify"
            },
            {
              "id": "q13d_person_alive",
              "text": "13d. Is the person alive?",
              "type": "radio",
              "options": [
                "Yes",
                "No"
              ]
            },
            {
              "id": "q13e_age_of_death",
              "text": "13e. Age of death",
              "type": "select",
              "options": [
                "Select age"
              ]
            },
            {
              "id": "q13f_ethnicity",
              "text": "13f. Please select your ethnicity:",
              "type": "select",
              "options": [
                "Select your ethnicity"
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Section 2: Breast Examination (BE)",
      "questions": [
        {
          "id": "q14_had_be",
          "text": "14. Have you ever undergone a Breast Examination (BE)?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q14a_last_be_time",
              "text": "14a. When was the last BE performed?",
              "type": "radio",
              "options": [
                "Within 1 year",
                "1-3 years",
                "More than 3 years ago"
              ]
            },
            {
              "id": "q14b_be_result",
              "text": "14b. Result of BE?",
              "type": "radio",
              "options": [
                "Normal \u2013 No abnormal findings",
                "Benign \u2013 Non-cancerous features (e.g., fibroadenoma, cyst)",
                "Suspicious \u2013 Unclear/possibly malignant features, needs further tests",
                "Malignant features \u2013 Strongly suggestive of breast cancer"
              ]
            }
          ]
        },
        {
          "id": "q15_lump_detected",
          "text": "15. During BE, was any lump or mass detected in your breast?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q15a_lump_location",
              "text": "15a. Specify location",
              "type": "checkbox",
              "options": [
                "Left",
                "Right",
                "Both"
              ]
            },
            {
              "id": "q15b_lump_size",
              "text": "15b. Size (approximate if known):",
              "type": "radio",
              "options": [
                "<1 cm",
                "1-2 cm",
                ">2 cm"
              ]
            },
            {
              "id": "q15c_lump_consistency",
              "text": "15c. Consistency:",
              "type": "radio",
              "options": [
                "Soft",
                "Firm",
                "Hard"
              ]
            }
          ]
        },
        {
          "id": "q16_pain_during_exam",
          "text": "16. Did you experience breast pain or tenderness during examination?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q16a_pain_location",
              "text": "16a. If yes, was it localized (in one specific spot) or generalized (spread across a wider area of the breast)?",
              "type": "radio",
              "options": [
                "Localized (in one specific spot)",
                "Generalized (spread across a wider area)"
              ]
            }
          ]
        },
        {
          "id": "q17_follow_up",
          "text": "17. After the BE, were you advised for further investigation or follow-up?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q17a_follow_up_type",
              "text": "17a. If Yes, specify:",
              "type": "checkbox",
              "options": [
                "Ultrasound",
                "Mammogram",
                "Biopsy",
                "Other"
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Section 3: Beyond BE",
      "questions": [

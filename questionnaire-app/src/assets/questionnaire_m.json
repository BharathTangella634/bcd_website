            "No"
          ],
          "subQuestions": [
            {
              "id": "q19a_biopsy_result",
              "text": "19a. Result of Biopsy (BIRAD Assessment)",
              "type": "radio",
              "options": [
                "N (1) Negative",
                "B (2) Benign",
                "P (3) Probably benign",
                "M (6) Malignancy"
              ]
            }
          ]
        },
        {
          "id": "q20_cancer_diagnosis",
          "text": "20. Have you ever been diagnosed with any type of cancer?",
          "type": "radio",
          "options": [
            "Yes",
            "No"
          ],
          "subQuestions": [
            {
              "id": "q20a_cancer_types",
              "text": "20a. Please specify which types of cancer:",
              "type": "checkbox-plus-text",
              "options": [
                "Breast cancer",
                "Ovarian cancer",
                "Colon, rectal, or pancreatic cancer",
                "Uterine cancer"
              ],
              "otherOptionId": "q20a_other_cancer_specify"
            }
          ]
        }
      ]
    }
  ]
}
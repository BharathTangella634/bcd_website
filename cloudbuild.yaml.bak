steps:
  # 1. Sync code to the VM and rebuild Docker containers
  - name: 'gcr.io/cloud-builders/gcloud'
    id: deploy-to-vm
    entrypoint: bash
    args:
      - '-c'
      - |
        gcloud compute ssh tanuh-bcd-vm \
          --zone=asia-south1-c \
          --project=$PROJECT_ID \
          --tunnel-through-iap \
          --command="sudo bash -c 'cd /app/tanuh_website && git fetch origin main && git reset --hard origin/main && chmod +x dc-rebuild.sh && ./dc-rebuild.sh'" \
          --ssh-flag="-o StrictHostKeyChecking=no"

  # 2. Wait for Docker containers to stabilize
  - name: 'gcr.io/cloud-builders/gcloud'
    id: health-check
    entrypoint: bash
    args:
      - '-c'
      - |
        for i in $$(seq 1 12); do
          gcloud compute ssh tanuh-bcd-vm \
            --zone=asia-south1-c --project=$PROJECT_ID \
            --tunnel-through-iap \
            --command="curl -sf http://localhost:3000/health && curl -sf http://localhost:3001/api/stats | head -c 20" \
            --ssh-flag="-o StrictHostKeyChecking=no" 2>/dev/null
          if [ $$? -eq 0 ]; then
            echo "Health check passed"
            exit 0
          fi
          echo "Attempt $$i/12 - waiting 10s..."
          sleep 10
        done
        echo "Health check failed after 2 minutes"
        exit 1

  # 3. Stop VM for clean disk snapshot
  - name: 'gcr.io/cloud-builders/gcloud'
    id: stop-vm
    args:
      - compute
      - instances
      - stop
      - tanuh-bcd-vm
      - '--zone=asia-south1-c'
      - '--project=$PROJECT_ID'

  # 4. Create timestamped boot image from VM disk
  - name: 'gcr.io/cloud-builders/gcloud'
    id: create-image
    entrypoint: bash
    args:
      - '-c'
      - |
        _IMG="tanuh-bcd-boot-${SHORT_SHA}-$$(date +%Y%m%d%H%M%S)"
        echo "$$_IMG" > /workspace/image_name.txt
        gcloud compute images create "$$_IMG" \
          --source-disk=tanuh-bcd-vm \
          --source-disk-zone=asia-south1-c \
          --project=$PROJECT_ID \
          --labels=app=tanuh-bcd,commit=${SHORT_SHA}

  # 5. Start VM back up immediately
  - name: 'gcr.io/cloud-builders/gcloud'
    id: start-vm
    args:
      - compute
      - instances
      - start
      - tanuh-bcd-vm
      - '--zone=asia-south1-c'
      - '--project=$PROJECT_ID'

  # 6. Create new instance template using the fresh image
  - name: 'gcr.io/cloud-builders/gcloud'
    id: create-template
    entrypoint: bash
    args:
      - '-c'
      - |
        _IMG=$$(cat /workspace/image_name.txt)
        _TMPL="tanuh-bcd-tmpl-${SHORT_SHA}-$$(date +%Y%m%d%H%M%S)"
        echo "$$_TMPL" > /workspace/template_name.txt

        gcloud compute instance-templates create "$$_TMPL" \
          --machine-type=e2-small \
          --image="$$_IMG" \
          --boot-disk-size=10GB \
          --boot-disk-type=pd-balanced \
          --tags=http-server,https-server \
          --scopes=cloud-platform \
          --network=default \
          --project=$PROJECT_ID

  # 7. Rolling-update MIG to the new template (zero-downtime)
  - name: 'gcr.io/cloud-builders/gcloud'
    id: update-mig
    entrypoint: bash
    args:
      - '-c'
      - |
        _TMPL=$$(cat /workspace/template_name.txt)

        gcloud compute instance-groups managed set-instance-template tanuh-bcd-mig \
          --template="$$_TMPL" \
          --zone=asia-south1-c \
          --project=$PROJECT_ID

        gcloud compute instance-groups managed rolling-action start-update tanuh-bcd-mig \
          --version=template="$$_TMPL" \
          --zone=asia-south1-c \
          --max-surge=1 \
          --max-unavailable=0 \
          --project=$PROJECT_ID

  # 8. Clean up old images and templates (keep last 3)
  - name: 'gcr.io/cloud-builders/gcloud'
    id: cleanup
    entrypoint: bash
    args:
      - '-c'
      - |
        echo "Cleaning up old boot images (keeping last 3)..."
        gcloud compute images list --project=$PROJECT_ID \
          --filter="name~tanuh-bcd-boot" \
          --sort-by=~creationTimestamp \
          --format="value(name)" | tail -n +4 | while read img; do
          echo "Deleting image: $$img"
          gcloud compute images delete "$$img" --project=$PROJECT_ID --quiet || true
        done

        echo "Cleaning up old instance templates (keeping last 3)..."
        gcloud compute instance-templates list --project=$PROJECT_ID \
          --filter="name~tanuh-bcd-tmpl" \
          --sort-by=~creationTimestamp \
          --format="value(name)" | tail -n +4 | while read tmpl; do
          echo "Deleting template: $$tmpl"
          gcloud compute instance-templates delete "$$tmpl" --project=$PROJECT_ID --quiet || true
        done

options:
  logging: CLOUD_LOGGING_ONLY

timeout: '1800s'
